{
  "manifest_version": 3,
  "name": "NewsAnchor",
  "version": "0.2.0",
  "description": "Affiche un popup déplaçable sur TradingView avec les annonces économiques liées à l'actif courant.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "NewsAnchor — afficher / masquer le popup",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.tradingview.com/*"
      ],
      "js": ["content/symbol-map.js", "content/content.js"],
      "css": ["content/popup.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://nfs.faireconomy.media/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2"],
      "matches": ["https://*.tradingview.com/*"]
    }
  ]
}
